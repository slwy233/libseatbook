{
  "expo": {
    "name": "座位预约",
    "slug": "seat-booker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1677FF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seatbooker.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1677FF"
      },
      "package": "com.seatbooker.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a5fe7e56-7f3e-4484-9fc1-229339013e36"
      }
    },
    "owner": "wuti"
  }
}
